# LIFF
VITE_LIFF_ID=

# Database (Neon PostgreSQL - Vercel Marketplace経由で自動設定)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Stripe決済
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# RemoteLock スマートロック連携
# OAuthアプリ認証情報
REMOTELOCK_CLIENT_ID=
REMOTELOCK_CLIENT_SECRET=
# デバイスID（RemoteLock APIのデバイスID、シリアル番号ではない）
# ASP玄関扉 (共用入口) - シリアル: AC000W017827101
REMOTELOCK_DEVICE_ID_ENTRANCE=
# ASP体育館 - シリアル: AC000W017830299
REMOTELOCK_DEVICE_ID_GYM=
# ASPトレーニングルーム - シリアル: AC000W017830548
REMOTELOCK_DEVICE_ID_TRAINING=

# App URL (Vercelデプロイ後に設定)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
