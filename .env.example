# LIFF
VITE_LIFF_ID=

# Firebase (サービスアカウントJSONをBase64エンコードした値)
# cat your-service-account.json | base64 | tr -d '\n' | pbcopy
FIREBASE_SERVICE_ACCOUNT_KEY=

# Stripe決済
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# RemoteLock スマートロック連携
# OAuthアプリ認証情報
REMOTELOCK_CLIENT_ID=
REMOTELOCK_CLIENT_SECRET=
# デバイスID（RemoteLock APIのデバイスID、シリアル番号ではない）
# ASP玄関扉 (共用入口) - シリアル: AC000W017827101
REMOTELOCK_DEVICE_ID_ENTRANCE=
# ASP体育館 - シリアル: AC000W017830299
REMOTELOCK_DEVICE_ID_GYM=
# ASPトレーニングルーム - シリアル: AC000W017830548
REMOTELOCK_DEVICE_ID_TRAINING=
# みんなの体育館八橋（やばせ） - シリアル: AC000W017827205
REMOTELOCK_DEVICE_ID_YABASE=

# App URL (Vercelデプロイ後に設定)
VITE_APP_URL=https://your-app.vercel.app

# 開発用: 決済スキップ（true で Stripe をスキップ）
# SKIP_PAYMENT=true
